# Edit this file to introduce tasks to be run by cron.
#
# Each task to run has to be defined through a single line
# indicating with different fields when the task will be run
# and what command to run for the task
#
# To define the time you can provide concrete values for
# minute (m), hour (h), day of month (dom), month (mon),
# and day of week (dow) or use '*' in these fields (for 'any').
#
# Notice that tasks will be started based on the cron's system
# daemon's notion of time and timezones.
#
# Output of the crontab jobs (including errors) is sent through
# email to the user the crontab file belongs to (unless redirected).
#
# For example, you can run a backup of all your user accounts
# at 5 a.m every week with:
# 0 5 * * 1 tar -zcf /var/backups/home.tgz /home/

MAILTO=piggy.yarroll+skol@gmail.com
SKOL_SITE_URL="https://synoptickeyof.life/skol"
COUCHDB_URL="http://localhost:5984"
INGEST_DATABASE="skol_dev"
TAXON_DATABASE="skol_taxa_dev"
LOGDIR=/var/log/skol
VERBOSITY=1
REDIS_PORT=6380
SKIP_EXISTING=1

# For more information see the manual pages of crontab(5) and cron(8)
#
# m h  dom mon dow user command
30 0 * * * skol time /opt/skol/bin/train_classifier > ${LOGDIR}/train-classifier-log 2>&1
0 1 * * 0 skol time /opt/skol/bin/ingest --publication fuse-rss > ${LOGDIR}/ingest-fuse-rss.log 2>&1
0 2 * * 0 skol time /opt/skol/bin/ingest --publication mycotaxon-rss > ${LOGDIR}/ingest-mycotaxon-rss.log 2>&1
0 3 * * 0 skol time /opt/skol/bin/ingest --publication studies-in-mycology-rss > ${LOGDIR}/ingest-studies-in-mycology-rss.log 2>&1
0 4 * * 0 skol time /opt/skol/bin/ingest --publication persoonia-rss > ${LOGDIR}/ingest-persoonia-rss.log 2>&1
0 5 * * 0 skol time /opt/skol/bin/ingest --publication jof-crossref > ${LOGDIR}/ingest-jof-crossref.log 2>&1
0 6 * * 0 skol time /opt/skol/bin/ingest --publication mycologie-crossref > ${LOGDIR}/ingest-mycologie-crossref.log 2>&1
0 7 * * 0 skol time /opt/skol/bin/ingest --publication mycoscience-crossref > ${LOGDIR}/ingest-mycoscience-crossref.log 2>&1
0 8 * * 0 skol time /opt/skol/bin/ingest --publication mycologia-crossref > ${LOGDIR}/ingest-mycologia-crossref.log 2>&1
0 9 * * 0 skol time /opt/skol/bin/ingest --publication mycology-crossref > ${LOGDIR}/ingest-mycology-crossref.log 2>&1
0 10 * * 0 skol time /opt/skol/bin/ingest --publication mycosphere > ${LOGDIR}/ingest-mycosphere.log 2>&1
0 11 * * 0 skol time /opt/skol/bin/ingest --publication oajmms > ${LOGDIR}/ingest-oajmms.log 2>&1
0 12 * * 0 skol time /opt/skol/bin/ingest --publication mycokeys > ${LOGDIR}/ingest-mycokeys.log 2>&1
0 13 * * 0 skol time /opt/skol/bin/ingest --publication imafungus > ${LOGDIR}/ingest-imafungus.log 2>&1
# PMC ingestors — scheduled after 9 PM ET (off-peak) to comply with NCBI policy:
# scripts making >100 requests must run outside Mon-Fri 5 AM – 9 PM ET.
# flock prevents concurrent PMC API requests (also required by NCBI policy).
0 21 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication fuse-pmc > ${LOGDIR}/ingest-fuse-pmc.log 2>&1
10 21 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication persoonia-pmc > ${LOGDIR}/ingest-persoonia-pmc.log 2>&1
20 21 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication sim-pmc > ${LOGDIR}/ingest-sim-pmc.log 2>&1
30 21 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication imafungus-pmc > ${LOGDIR}/ingest-imafungus-pmc.log 2>&1
40 21 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication mycokeys-pmc > ${LOGDIR}/ingest-mycokeys-pmc.log 2>&1
50 21 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication jof-pmc > ${LOGDIR}/ingest-jof-pmc.log 2>&1
0 22 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication mycoscience-pmc > ${LOGDIR}/ingest-mycoscience-pmc.log 2>&1
10 22 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication mycology-pmc > ${LOGDIR}/ingest-mycology-pmc.log 2>&1
20 22 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication fungal-biol-biotechnol-pmc > ${LOGDIR}/ingest-fungal-biol-biotechnol-pmc.log 2>&1
30 22 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication front-fungal-biol-pmc > ${LOGDIR}/ingest-front-fungal-biol-pmc.log 2>&1
40 22 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication mycobiology-pmc > ${LOGDIR}/ingest-mycobiology-pmc.log 2>&1
50 22 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication curr-med-mycol-pmc > ${LOGDIR}/ingest-curr-med-mycol-pmc.log 2>&1
0 23 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/ingest --publication med-mycol-case-rep-pmc > ${LOGDIR}/ingest-med-mycol-case-rep-pmc.log 2>&1
# Extract plaintext (article.txt) from newly-ingested PDFs / JATS / efetch.
# Runs after the PMC ingesters and before predict_classifier (00:00) so the
# classifier always sees fresh article.txt attachments.  Shares the PMC flock
# because --source auto tries efetch first, which is an NCBI eutils call —
# subject to the same off-peak / serialization policy as the PMC ingesters.
30 23 * * * skol flock /var/lock/skol-pmc.lock time /opt/skol/bin/extract_plaintext --all --skip-existing -v > ${LOGDIR}/extract-plaintext.log 2>&1
# Generate YEDDA training data from newly ingested articles (after PMC/Pensoft ingesters)
30 17 * * * skol time /opt/skol/bin/jats_to_yedda --all --output-to couchdb --skip-existing > ${LOGDIR}/jats-to-yedda.log 2>&1
0 0 * * * skol time /opt/skol/bin/predict_classifier --cores=2 --batch-size=24 --spark-driver-memory=8g --spark-executor-memory=8g --union-batch-size=1000 --verbosity=2 --save-text=lazy --incremental --incremental-batch-size=50 --retry-failed-extraction > ${LOGDIR}/predict-classifier.log 2>&1
0 4 * * * skol time /opt/skol/bin/extract_treatments_to_couchdb --verbosity=2 > ${LOGDIR}/extract-treatments-to-couchdb.log 2>&1
0 6 * * * skol time /opt/skol/bin/embed_treatments --verbosity=2 --expire None --force > ${LOGDIR}/embed-treatments.log 2>&1
0 22 * * * skol time /opt/skol/bin/treatments_to_json --verbosity=2 --incremental --skip-existing --use-constrained-decoding --graceful-degradation --timeout 1200 > ${LOGDIR}/treatments-to-json.log 2>&1
0 22 * * 0,2,4,6 skol time /opt/skol/bin/build_vocab_tree --verbosity=2 --db=skol_taxa_full_dev > ${LOGDIR}/build-vocab-tree.log 2>&1
# v3_hand experiment — keeps the v3 hand-only baseline up to date so the
# v3_hand Treatments + embeddings track new docs ingested into skol_dev.
# Slots are offset from the v1 jobs (predict 00:00, extract 04:00, embed
# 06:00) to avoid Spark / GPU contention.  Training is weekly because the
# v3_hand training corpus is fixed.  See docs/v3_buildout.md §Phase E.
30 3 * * 0 skol time /opt/skol/bin/manage_experiment runstep production_v3_hand train > ${LOGDIR}/v3_hand-train.log 2>&1
0 12 * * * skol time /opt/skol/bin/manage_experiment runstep production_v3_hand predict > ${LOGDIR}/v3_hand-predict.log 2>&1
0 14 * * * skol time /opt/skol/bin/manage_experiment runstep production_v3_hand extract_taxa > ${LOGDIR}/v3_hand-extract.log 2>&1
0 16 * * * skol time /opt/skol/bin/manage_experiment runstep production_v3_hand embed > ${LOGDIR}/v3_hand-embed.log 2>&1
# treatments_to_json runs last in the v3_hand daily chain — LLM-based and
# slow, but independent of embed (reads from treatments DB, writes to the
# per-experiment treatments_full DB consumed by the Django JSON Features
# endpoint).  Spaced 2h after embed to leave the GPU clear.
0 18 * * * skol time /opt/skol/bin/manage_experiment runstep production_v3_hand treatments_to_json > ${LOGDIR}/v3_hand-treatments-to-json.log 2>&1
# Sync Plazi treatment UUIDs onto skol_dev docs.  Daily at 7pm ET =
# 01:00 in Bern (Switzerland), Plazi's deepest off-peak hour, before
# the European workday starts.  Pittsburgh is 6 h behind Bern
# year-round so this slot is stable across DST transitions.  Slot is
# clear locally: the 18:00 v3_hand jobs are wrapping up and the
# 21:00 PMC ingestor band hasn't started.  The
# --re-check-after-days 14 freshness guard keeps most daily runs
# cheap — only docs whose lookup is older than 14 days (≈ 1/14 of
# the corpus per day plus any newly-ingested docs) get re-queried.
# At the default 1-2 s/request pace, ≈ 1700 docs/day = ~20 min wall.
0 19 * * * skol time /opt/skol/bin/backfill_plazi_uuids --re-check-after-days 14 --verbosity 1 > ${LOGDIR}/backfill-plazi.log 2>&1
# Update sources statistics for the ingestion sources page daily at 7am
0 7 * * * skol time /opt/skol/bin/build_sources_stats --verbosity=2 > ${LOGDIR}/build-sources-stats.log 2>&1
# Per-experiment Ingestion Sources stats (writes the experiment-scoped
# Redis key ``skol:sources:stats:<experiment>``).  Slot after the v3_hand
# treatments_to_json daily run so the treatments_full counts surface
# alongside the treatments counts on the per-experiment Sources page.
30 18 * * * skol time /opt/skol/bin/manage_experiment runstep production_v3_hand build_sources_stats > ${LOGDIR}/v3_hand-build-sources-stats.log 2>&1
*/5 * * * * skol /usr/bin/redis-cli -p ${REDIS_PORT} save
# Daily admin report at 6am — stdout goes to MAILTO, emails to opted-in users
0 6 * * * skol /opt/skol/bin/daily_report --send 2>> ${LOGDIR}/daily-report.log
# Update fungaria registry from Index Herbariorum monthly (1st of each month at 3am)
0 3 1 * * skol time /opt/skol/bin/manage_fungaria download --expire=0 > ${LOGDIR}/manage-fungaria.log 2>&1
