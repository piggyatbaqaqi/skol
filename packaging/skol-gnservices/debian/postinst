#!/bin/sh
# postinst — runs after files are unpacked.  Create the skol-gn
# system user the systemd units expect, then let dh_installsystemd's
# inserted fragment enable + start gnfinder + gnparser.
set -e

case "$1" in
    configure)
        if ! getent passwd skol-gn >/dev/null; then
            adduser --system --group --no-create-home \
                --home /nonexistent --gecos "skol gnservices" \
                --shell /usr/sbin/nologin skol-gn
        fi
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
