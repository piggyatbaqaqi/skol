# SKOL Environment Configuration
# Copy this file to /home/skol/.skol_env and fill in your values
# chmod 600 /home/skol/.skol_env

# =============================================================================
# CouchDB Configuration
# =============================================================================
COUCHDB_USER=admin
COUCHDB_PASSWORD=CHANGEME_couchdb_password

# URL for CouchDB access (plain HTTP for localhost, container handles TLS)
COUCHDB_URL=http://localhost:5984

# Database names
INGEST_DATABASE=skol_dev
TAXON_DATABASE=taxa

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_USERNAME=default
REDIS_PASSWORD=CHANGEME_redis_password

# Enable TLS for Redis connections (true/false)
REDIS_TLS=true

# -----------------------------------------------------------------------------
# Redis Cluster (Phase 2+ of skol→tsqali migration)
# -----------------------------------------------------------------------------
# Server side: when REDIS_CLUSTER_ENABLED=yes the redis docker container
# starts with cluster mode on and the entrypoint bootstraps all 16384 slots
# to itself.  Set ONLY on the host that runs the cluster node (tsqali).
# Default: unset (no cluster mode).
#REDIS_CLUSTER_ENABLED=yes
#
# Address that clients see in CLUSTER NODES output and use for MOVED
# redirects.  MUST be reachable from every client (the public IP, the LAN
# hostname, or 127.0.0.1 for a single-host setup).  Required when ENABLED=yes.
#REDIS_CLUSTER_ANNOUNCE_IP=23.25.95.129
#
# Ports the cluster announces.  Both PORT and TLS_PORT exist because Redis
# emits *cluster-announce-tls-port* (NOT cluster-announce-port) when
# tls-cluster is enabled in redis.conf — which it is in our setup.  So
# REDIS_CLUSTER_ANNOUNCE_TLS_PORT is the load-bearing one in practice; set
# both to keep them consistent in case tls-cluster is ever flipped off.
# Match these to whatever externally-visible port maps to the container's
# tls-port (6379 inside) — e.g. the SSH reverse-tunnel port on skol, or
# the docker-compose host-side mapping.
#REDIS_CLUSTER_ANNOUNCE_PORT=6381
#REDIS_CLUSTER_ANNOUNCE_TLS_PORT=6381
#REDIS_CLUSTER_ANNOUNCE_BUS_PORT=16381
#
# Client side: when REDIS_CLUSTER_MODE=yes, env_config.create_redis_client
# returns a redis.cluster.RedisCluster instance instead of redis.Redis.
# Set on every host whose skol app code talks to the cluster.
#REDIS_CLUSTER_MODE=yes

# =============================================================================
# Email Configuration (for notifications and error reports)
# =============================================================================
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=CHANGEME_email_password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=skol@example.com

# Email address for cron job notifications
MAILTO=admin@example.com

# =============================================================================
# NCBI E-utilities Configuration
# =============================================================================
# API key from https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/
# Without a key, rate limit is 3 requests/sec; with a key, 10 requests/sec
NCBI_API_KEY=

# =============================================================================
# Logging Configuration
# =============================================================================
LOGDIR=/var/log/skol
VERBOSITY=1

# =============================================================================
# Model Configuration
# =============================================================================
# Classifier model expiration time in Redis (empty = no expiration)
# Format: HH:MM:SS or empty string
CLASSIFIER_MODEL_EXPIRE=

# =============================================================================
# Django Configuration (for web interface)
# =============================================================================
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGEME_django_secret_key

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.example.com

# =============================================================================
# Site URL (for links in reports and notifications)
# =============================================================================
SKOL_SITE_URL=https://yourdomain.example.com/skol
